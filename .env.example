# Public app URL from Vercel. Example: https://ibo-funds-purchase.vercel.app
NEXT_PUBLIC_BASE_URL=

# Google service account credentials
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nPASTE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Google Sheet ID from the sheet URL
GOOGLE_SHEET_ID=

# Optional. Google Drive folder ID for receipt uploads. Share the folder with the service account email.
GOOGLE_DRIVE_FOLDER_ID=

# SMTP email settings. Gmail requires an app password, not your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="In Becoming One <your-email@example.com>"
